# Host port the local Postgres container maps to (see docker-compose.yml).
# Defaults to 5432; override if you already run Postgres on 5432.
DB_PORT=5432

# Postgres connection string. Left empty on purpose — fill per environment.
# Local dev (matches docker-compose.yml, using DB_PORT above):
#   postgresql://inbox:inbox@localhost:5432/inbox?schema=public
DATABASE_URL=

# Anthropic API key. Left empty on purpose — never commit a real key.
ANTHROPIC_API_KEY=

# Model the agent uses. Read from env, never hardcoded in logic, so the price
# map in lib/agent/cost.ts and the model stay in sync. Default: current Sonnet.
ANTHROPIC_MODEL=claude-sonnet-4-6
